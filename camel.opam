# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
synopsis: "OCaml rewrite of Claude Code CLI"
description:
  "Two humps, zero runtime. A full OCaml port of the Claude Code terminal assistant."
authors: ["Liam Nguyen"]
license: "MIT"
depends: [
  "ocaml" {>= "5.1"}
  "dune" {>= "3.16" & >= "3.16"}
  "yojson" {>= "2.1"}
  "uri" {>= "4.4"}
  "alcotest" {>= "1.7" & with-test}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "http://gitea.chill/liam/camel-code"
