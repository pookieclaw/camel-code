# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
synopsis: "Terminal AI coding assistant in OCaml"
description:
  "An independent terminal AI coding assistant built with OCaml 5. Uses the Anthropic Messages API. Not affiliated with Anthropic."
authors: ["Camel Code Contributors"]
license: "MIT"
homepage: "https://github.com/liam/camel-code"
bug-reports: "https://github.com/liam/camel-code/issues"
depends: [
  "ocaml" {>= "5.1"}
  "dune" {>= "3.16" & >= "3.16"}
  "yojson" {>= "2.1"}
  "uri" {>= "4.4"}
  "alcotest" {>= "1.7" & with-test}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/liam/camel-code.git"
